//@version=6
indicator("TradingView 3-Stop Spread Indicator", overlay=true, max_labels_count=500, max_lines_count=500)

// ==========================================
// --- INPUTS & COLOR CONFIGURATIONS ---
// ==========================================
// Group: Trade Settings
G_TRADE = "Trade Configuration"
tradeDirection   = input.string("Long (Buy)", "Trade Type", options=["Long (Buy)", "Short (Sell)"], group=G_TRADE)
positionSize     = input.float(3.0, "Position Size (Shares)", minval=0.0, group=G_TRADE)
allowFractional  = input.bool(false, "Allow Fractional Shares", group=G_TRADE)
useManualDate    = input.bool(false, "Use Manual Entry Date & Time", group=G_TRADE)
entryTime        = input.time(timestamp("2026-07-10 00:00"), "Manual Entry Date & Time", group=G_TRADE, tooltip="Configure the manual entry time. Active only if 'Use Manual Entry Date & Time' is checked.")
entryPriceLevel  = input.string("Close", "Entry Price Level", options=["Close", "Open", "Breakout (High/Low)", "Pullback (Low/High)"], group=G_TRADE, tooltip="Close: Close price of the entry bar.\nOpen: Open price of the entry bar.\nBreakout: Entry bar High (Long) / Low (Short).\nPullback: Entry bar Low (Long) / High (Short).")
manualEntryPrice = input.float(0.0, "Manual Entry Price Override", minval=0.0, group=G_TRADE, tooltip="If set to greater than 0, this manual price overrides the Entry Price Level setting.")
stopPriceLevel   = input.string("Session Low/High", "Stop Loss Price Level", options=["Session Low/High", "Entry Bar Low/High", "Prev Bar Low/High", "Swing Low/High", "Moving Average"], group=G_TRADE)
manualStopPrice  = input.float(0.0, "Manual Stop Loss Override", minval=0.0, group=G_TRADE, tooltip="If set to greater than 0, this manual price overrides the Stop Loss Price Level setting.")

// Group: Moving Average & Swing Configuration
G_MA             = "Moving Average & Swing Configuration"
maType           = input.string("SMA", "Moving Average Type", options=["SMA", "EMA"], group=G_MA, tooltip="SMA: Simple Moving Average.\nEMA: Exponential Moving Average.")
maLength         = input.int(20, "Moving Average Length", minval=1, group=G_MA)
swingLookbackPeriod = input.int(10, "Swing Lookback Period", minval=1, group=G_MA, tooltip="Lookback length (in bars) used to calculate the Swing Low / High Stop Loss level.")

// Group: Dashboard & UI Layout
G_UI = "Dashboard & UI Layout"
showDashboard    = input.bool(true, "Display Dashboard Widget", group=G_UI)
dashboardPosStr  = input.string("Bottom Left", "Widget Position", options=["Top Left", "Top Center", "Top Right", "Middle Left", "Middle Center", "Middle Right", "Bottom Left", "Bottom Center", "Bottom Right"], group=G_UI)
tableTextSizeStr = input.string("Normal", "Widget Font Size", options=["Auto", "Tiny", "Small", "Normal", "Large", "Huge"], group=G_UI)
tableTheme       = input.string("Aqua Gold (Default)", "Dashboard Color Theme", options=["Aqua Gold (Default)", "GitHub Light", "Atom One Light", "One Dark Pro", "Dracula", "Custom Theme"], group=G_UI)

// Custom Theme Colors (Only used if Theme is "Custom Theme")
custom_text      = input.color(color.black, "Text Color", group=G_UI, inline="Custom 1")
custom_bg        = input.color(color.white, "Background Color", group=G_UI, inline="Custom 1")
custom_border    = input.color(#363a45, "Border Color", group=G_UI, inline="Custom 2")
custom_frame     = input.color(color.new(color.blue, 0), "Frame Color", group=G_UI, inline="Custom 2")
custom_title_bg  = input.color(color.new(color.yellow, 75), "Title Row BG", group=G_UI, inline="Custom 3")
custom_header_bg = input.color(color.new(color.aqua, 85), "Header Row BG", group=G_UI, inline="Custom 3")

// Group: Chart Level Visuals
G_DRAW            = "Chart Level Visuals"
colorEntry        = input.color(color.blue, "Entry Level Color", group=G_DRAW, inline="Line Colors")
colorStopsStag    = input.color(color.orange, "Staggered Stops Color", group=G_DRAW, inline="Line Colors")
colorStops        = input.color(color.red, "Final Stop Color", group=G_DRAW, inline="Line Colors")
lineWidthEntry    = input.int(2, "Entry Line Width", minval=1, group=G_DRAW, inline="Line Widths")
lineWidthStops    = input.int(2, "Stop Lines Width", minval=1, group=G_DRAW, inline="Line Widths")
lineStyleStr      = input.string("Dotted", "Level Line Style", options=["Solid", "Dotted", "Dashed"], group=G_DRAW)
labelSpacing      = input.int(1, "Label Offset (Bars)", minval=0, group=G_DRAW)

// Theme Color Resolution
color txt_color = na
color border_color = na
color frame_color = na
color title_bg_color = na
color body_bg_color = na
color bad_bg_color = na
color bg_color = na
color stop1_bg_color = na
color stop2_bg_color = na
color stop3_bg_color = na

if tableTheme == "Aqua Gold (Default)" or tableTheme == "Aqua Gold"
    txt_color      := color.black
    border_color   := #363a45
    frame_color    := color.new(color.blue, 0)
    title_bg_color := color.new(color.yellow, 75)
    body_bg_color  := color.new(color.aqua, 85)
    bad_bg_color   := color.new(color.red, 40)
    bg_color       := color.white
    stop1_bg_color := color.new(colorStopsStag, 90)
    stop2_bg_color := color.new(colorStopsStag, 90)
    stop3_bg_color := color.new(colorStops, 90)
else if tableTheme == "GitHub Light"
    txt_color      := #24292f
    border_color   := #d0d7de
    frame_color    := #0969da
    title_bg_color := #f6f8fa
    body_bg_color  := #ffffff
    bad_bg_color   := color.new(#cf222e, 35)
    bg_color       := #ffffff
    stop1_bg_color := color.new(#af5b00, 90) // GitHub Light Orange tint
    stop2_bg_color := color.new(#af5b00, 90)
    stop3_bg_color := color.new(#cf222e, 90) // GitHub Light Red tint
else if tableTheme == "Atom One Light"
    txt_color      := #383a42
    border_color   := #e5e5e6
    frame_color    := #4078f2
    title_bg_color := #f0f0f1
    body_bg_color  := #fafafa
    bad_bg_color   := color.new(#e45649, 35)
    bg_color       := #fafafa
    stop1_bg_color := color.new(#d19a66, 85) // One Light Orange tint
    stop2_bg_color := color.new(#d19a66, 85)
    stop3_bg_color := color.new(#e45649, 85) // One Light Red tint
else if tableTheme == "One Dark Pro"
    txt_color      := #abb2bf
    border_color   := #3e4452
    frame_color    := #61afef
    title_bg_color := #21252b
    body_bg_color  := #2c313c
    bad_bg_color   := color.new(#e06c75, 30)
    bg_color       := #282c34
    stop1_bg_color := color.new(#d19a66, 80) // One Dark Orange tint
    stop2_bg_color := color.new(#d19a66, 80)
    stop3_bg_color := color.new(#e06c75, 80) // One Dark Red tint
else if tableTheme == "Dracula"
    txt_color      := #f8f8f2
    border_color   := #44475a
    frame_color    := #bd93f9
    title_bg_color := #1e1f29
    body_bg_color  := #282a36
    bad_bg_color   := color.new(#ff5555, 30)
    bg_color       := #282a36
    stop1_bg_color := color.new(#ffb86c, 80) // Dracula Orange tint
    stop2_bg_color := color.new(#ffb86c, 80)
    stop3_bg_color := color.new(#ff5555, 80) // Dracula Red tint
else // "Custom Theme" or "Custom"
    txt_color      := custom_text
    border_color   := custom_border
    frame_color    := custom_frame
    title_bg_color := custom_title_bg
    body_bg_color  := custom_header_bg
    bad_bg_color   := color.new(color.red, 40)
    bg_color       := custom_bg
    stop1_bg_color := color.new(colorStopsStag, 90)
    stop2_bg_color := color.new(colorStopsStag, 90)
    stop3_bg_color := color.new(colorStops, 90)

// Map back to table variables
color_text     = txt_color
color_border   = border_color
color_frame    = frame_color
color_title_bg = title_bg_color
color_body_bg  = body_bg_color
color_bad_bg   = bad_bg_color
color_bg       = bg_color
color_stop1_bg = stop1_bg_color
color_stop2_bg = stop2_bg_color
color_stop3_bg = stop3_bg_color
frame_width    = 2
border_width   = 1

// ==========================================
// --- HELPERS & CALCULATION SAFETY ---
// ==========================================
isLong = (tradeDirection == "Long" or tradeDirection == "Long (Buy)")

// Calculate moving average and swing values globally
maValue = (maType == "SMA (Simple Moving Average)" or maType == "SMA") ? ta.sma(close, maLength) : ta.ema(close, maLength)
swingLowGlobal = ta.lowest(low, swingLookbackPeriod)
swingHighGlobal = ta.highest(high, swingLookbackPeriod)

// ==========================================
// --- LEVEL EXTRACTION & STOPS MATH ---
// ==========================================
// Track values extracted on the entry bar
var int entryBarIdx = na
var float entryPriceVal = na
var float finalStopPriceVal = na
var float entryDayLow = na
var float entryDayHigh = na
var int entryDayTime = na

var float stop1Price = na
var float stop2Price = na
var float stop3Price = na

// Check for entry bar on every bar
timeD = nz(time("D"), time)
isAutoMode = not useManualDate
bool isThisEntry = false
if not isAutoMode
    isThisEntry := (time >= entryTime) and (time[1] < entryTime or na(time[1]))
else
    isThisEntry := (ta.change(timeD) != 0 or barstate.isfirst)

if isThisEntry
    entryBarIdx := bar_index
    if manualEntryPrice > 0.0
        entryPriceVal := manualEntryPrice
    else
        entryPriceVal := switch entryPriceLevel
            "Close of Entry Bar"            => close
            "Close"                         => close
            "Open of Entry Bar"             => open
            "Open"                          => open
            "Breakout (Entry Bar High/Low)" => isLong ? high : low
            "Breakout (High / Low)"         => isLong ? high : low
            "Breakout (High/Low)"           => isLong ? high : low
            "Pullback (Entry Bar Low/High)" => isLong ? low : high
            "Pullback (Low / High)"         => isLong ? low : high
            "Pullback (Low/High)"           => isLong ? low : high
            => close
        
    if manualStopPrice > 0.0
        finalStopPriceVal := manualStopPrice
    else
        finalStopPriceVal := switch stopPriceLevel
            "Entry Bar Low/High"            => isLong ? low : high
            "Entry Bar Low / High"          => isLong ? low : high
            "Prev Bar Low/High"             => isLong ? nz(low[1], low) : nz(high[1], high)
            "Previous Bar Low / High"       => isLong ? nz(low[1], low) : nz(high[1], high)
            "Swing Low/High"                => isLong ? nz(swingLowGlobal, low) : nz(swingHighGlobal, high)
            "Recent Swing Low / High"       => isLong ? nz(swingLowGlobal, low) : nz(swingHighGlobal, high)
            "Swing Low / High"              => isLong ? nz(swingLowGlobal, low) : nz(swingHighGlobal, high)
            "Moving Average"                => nz(maValue, close)
            "Moving Average Value"          => nz(maValue, close)
            => isLong ? low : high
        
    entryDayTime := timeD
    entryDayLow := low
    entryDayHigh := high

// Track entry day low and high dynamically on each bar
if not na(entryDayTime) and timeD == entryDayTime
    entryDayLow := math.min(entryDayLow, low)
    entryDayHigh := math.max(entryDayHigh, high)

// Calculate stops on the last bar
if barstate.islast and not na(entryBarIdx)
    // Update Low of Day if selected and not overridden
    if (stopPriceLevel == "Session Low/High" or stopPriceLevel == "Session Low / High" or stopPriceLevel == "Day Low / High") and not (manualStopPrice > 0.0)
        finalStopPriceVal := isLong ? entryDayLow : entryDayHigh
        
    float r = math.max(0.000001, math.abs(entryPriceVal - finalStopPriceVal))
    stop1Price := isLong ? entryPriceVal - r / 3.0 : entryPriceVal + r / 3.0
    stop2Price := isLong ? entryPriceVal - 2.0 * r / 3.0 : entryPriceVal + 2.0 * r / 3.0
    stop3Price := finalStopPriceVal

// Calculate share quantities
float q1 = 0.0
float q2 = 0.0
float q3 = 0.0

if allowFractional
    q1 := positionSize * 0.33
    q2 := positionSize * 0.33
    q3 := positionSize * 0.34
else
    q1 := math.round(positionSize * 0.33)
    q2 := math.round(positionSize * 0.33)
    q3 := positionSize - q1 - q2

// Day Progression Tracker (inside table only)
int daysActive = 0
if not na(entryBarIdx)
    int offset = bar_index - entryBarIdx
    int lastDayTime = nz(time("D")[offset], time[offset])
    if offset > 0
        for i = 0 to offset - 1
            int idx = offset - 1 - i
            int currentDayVal = nz(time("D")[idx], time[idx])
            if currentDayVal != lastDayTime
                daysActive := daysActive + 1
                lastDayTime := currentDayVal

// ==========================================
// --- CHART DRAWINGS (ENTRY & STOPS) ---
// ==========================================
var line lineEntry = na
var line lineStop1 = na
var line lineStop2 = na
var line lineStop3 = na

var label labelEntry = na
var label labelStop1 = na
var label labelStop2 = na
var label labelStop3 = na

var linefill fillEntryStop1 = na
var linefill fillStop1Stop2 = na
var linefill fillStop2Stop3 = na

getCurrencySymbol() =>
    switch syminfo.currency
        "USD" => "$"
        "EUR" => "€"
        "GBP" => "£"
        "JPY" => "¥"
        "INR" => "₹"
        "CAD" => "$"
        "AUD" => "$"
        "CHF" => "CHF"
        "CNY" => "¥"
        "HKD" => "$"
        "NZD" => "$"
        "SGD" => "$"
        "ZAR" => "R"
        "KRW" => "₩"
        "TRY" => "₺"
        "RUB" => "₽"
        "BRL" => "R$"
        "MXN" => "$"
        => syminfo.currency

formatPrice(val) =>
    na(val) ? "-" : getCurrencySymbol() + " " + str.tostring(val, "#.##")

formatQty(val) =>
    na(val) ? "-" : (allowFractional ? str.tostring(val, "#.##") : str.tostring(math.round(val), "#"))

getOrdinalSuffix(dayVal) =>
    int lastDigit = dayVal % 10
    int lastTwoDigits = dayVal % 100
    if lastTwoDigits >= 11 and lastTwoDigits <= 13
        "th"
    else if lastDigit == 1
        "st"
    else if lastDigit == 2
        "nd"
    else if lastDigit == 3
        "rd"
    else
        "th"

getMonthName(mVal) =>
    switch mVal
        1  => "January"
        2  => "February"
        3  => "March"
        4  => "April"
        5  => "May"
        6  => "June"
        7  => "July"
        8  => "August"
        9  => "September"
        10 => "October"
        11 => "November"
        12 => "December"
        => ""

formatEntryDate(tVal) =>
    if na(tVal)
        "-"
    else
        int d = dayofmonth(tVal)
        int m = month(tVal)
        int y = year(tVal)
        str.tostring(d) + getOrdinalSuffix(d) + " " + getMonthName(m) + ", " + str.tostring(y)

if barstate.islast
    // Always clean up previous drawings on the last bar to prevent visual leakage/duplications
    line.delete(lineEntry)
    line.delete(lineStop1)
    line.delete(lineStop2)
    line.delete(lineStop3)
    
    label.delete(labelEntry)
    label.delete(labelStop1)
    label.delete(labelStop2)
    label.delete(labelStop3)
    
    linefill.delete(fillEntryStop1)
    linefill.delete(fillStop1Stop2)
    linefill.delete(fillStop2Stop3)
    
    if not na(entryBarIdx)
        lineStyle = switch lineStyleStr
            "Solid"  => line.style_solid
            "Dashed" => line.style_dashed
            "Dotted" => line.style_dotted
            => line.style_dotted
        // Create new line levels extending from entry day (using + 1 offset to define horizontal direction)
        lineEntry := line.new(entryBarIdx, entryPriceVal, entryBarIdx + 1, entryPriceVal, color=colorEntry, width=lineWidthEntry, style=lineStyle, extend=extend.right)
        lineStop1 := line.new(entryBarIdx, stop1Price, entryBarIdx + 1, stop1Price, color=colorStopsStag, width=lineWidthStops, style=lineStyle, extend=extend.right)
        lineStop2 := line.new(entryBarIdx, stop2Price, entryBarIdx + 1, stop2Price, color=colorStopsStag, width=lineWidthStops, style=lineStyle, extend=extend.right)
        lineStop3 := line.new(entryBarIdx, stop3Price, entryBarIdx + 1, stop3Price, color=colorStops, width=lineWidthStops, style=lineStyle, extend=extend.right)
        
        // Fill the spaces between the lines (using linefill.new)
        fillEntryStop1 := linefill.new(lineEntry, lineStop1, color.new(colorEntry, 90))
        fillStop1Stop2 := linefill.new(lineStop1, lineStop2, color.new(colorStopsStag, 90))
        fillStop2Stop3 := linefill.new(lineStop2, lineStop3, color.new(colorStops, 90))
    
        // Create new labels at the last bar matching the line colors with solid backgrounds and white text (shifted by spacing into future margin)
        labelEntry := label.new(bar_index + labelSpacing, entryPriceVal, "Entry: " + formatPrice(entryPriceVal) + " (" + formatQty(positionSize) + " Shares)", color=colorEntry, textcolor=color.white, style=label.style_label_left)
        labelStop1 := label.new(bar_index + labelSpacing, stop1Price, "Stop 1 (33%): " + formatPrice(stop1Price) + " (Qty: " + formatQty(q1) + ")", color=colorStopsStag, textcolor=color.white, style=label.style_label_left)
        labelStop2 := label.new(bar_index + labelSpacing, stop2Price, "Stop 2 (66%): " + formatPrice(stop2Price) + " (Qty: " + formatQty(q2) + ")", color=colorStopsStag, textcolor=color.white, style=label.style_label_left)
        labelStop3 := label.new(bar_index + labelSpacing, stop3Price, "Stop 3 (100%): " + formatPrice(stop3Price) + " (Qty: " + formatQty(q3) + ")", color=colorStops, textcolor=color.white, style=label.style_label_left)

// ==========================================
// --- HUD DASHBOARD TABLE ---
// ==========================================
getTablePos(pos) =>
    switch pos
        "Top Left"      => position.top_left
        "Top Center"     => position.top_center
        "Top Right"     => position.top_right
        "Middle Left"    => position.middle_left
        "Middle Center"  => position.middle_center
        "Middle Right"   => position.middle_right
        "Bottom Left"    => position.bottom_left
        "Bottom Center"  => position.bottom_center
        "Bottom Right"   => position.bottom_right
        => position.bottom_left

getTableTextSize(sz) =>
    switch sz
        "Auto"   => size.auto
        "Tiny"   => size.tiny
        "Small"  => size.small
        "Normal" => size.normal
        "Large"  => size.large
        "Huge"   => size.huge
        => size.normal

cell(t, col, row, txt, bg, fg, sz, fmt=text.format_none) =>
    table.cell(t, col, row, text=txt, bgcolor=bg, text_color=fg, text_size=sz, text_halign=text.align_center, text_valign=text.align_center, text_formatting=fmt)

var table hudTable = table.new(position = getTablePos(dashboardPosStr), columns = 4, rows = 6, bgcolor = color_bg, border_width = border_width, border_color = color_border, frame_color = color_frame, frame_width = frame_width)

if showDashboard and barstate.islast
    table.clear(hudTable, 0, 0, 3, 5)
    txtSize = getTableTextSize(tableTextSizeStr)
    if na(entryBarIdx)
        errorMsg = isAutoMode ? "Entry bar not found (Check ticker history)" : "Entry Date not found or in future (" + str.format("{0,date,yyyy-MM-dd}", entryTime) + ")"
        table.cell(hudTable, 0, 0, errorMsg, bgcolor=color_bad_bg, text_color=color.white, text_size=txtSize, text_halign=text.align_center)
    else
        // Row 0: Trade Status Summary Bar (using header row background color and bold text)
        tradeTypeStr = isLong ? "Long" : "Short"
        daysElapsedStr = "Days Elapsed: " + str.tostring(daysActive)
        cell(hudTable, 0, 0, syminfo.ticker + " (" + tradeTypeStr + ")", color_title_bg, color_text, txtSize, text.format_bold)
        cell(hudTable, 1, 0, "Entry: " + formatEntryDate(entryDayTime), color_title_bg, color_text, txtSize, text.format_bold)
        cell(hudTable, 2, 0, daysElapsedStr, color_title_bg, color_text, txtSize, text.format_bold)
        slSourceStr = manualStopPrice > 0.0 ? "Manual Override" : (stopPriceLevel == "Session Low / High" ? "Session Low/High" : (stopPriceLevel == "Moving Average Value" ? "Moving Average" : stopPriceLevel))
        cell(hudTable, 3, 0, "SL Source: " + slSourceStr, color_title_bg, color_text, txtSize, text.format_bold)
        
        // Row 1: Column Headers (using regular body row background color and bold text)
        cell(hudTable, 0, 1, "Stop Loss Levels", color_body_bg, color_text, txtSize, text.format_bold)
        cell(hudTable, 1, 1, "Price", color_body_bg, color_text, txtSize, text.format_bold)
        cell(hudTable, 2, 1, "Quantity (" + formatQty(positionSize) + ")", color_body_bg, color_text, txtSize, text.format_bold)
        cell(hudTable, 3, 1, "Description", color_body_bg, color_text, txtSize, text.format_bold)
        
        // Row 2: Stop Level 1 (colored same as Stop 1 fill level)
        colorStop1Row = color_stop1_bg
        cell(hudTable, 0, 2, "Stop 1 (33%)", colorStop1Row, color_text, txtSize)
        cell(hudTable, 1, 2, formatPrice(stop1Price), colorStop1Row, color_text, txtSize)
        cell(hudTable, 2, 2, formatQty(q1), colorStop1Row, color_text, txtSize)
        cell(hudTable, 3, 2, "Scale out 1/3 of position. Dampen exposure early.", colorStop1Row, color_text, txtSize)
        
        // Row 3: Stop Level 2 (colored same as Stop 2 fill level)
        colorStop2Row = color_stop2_bg
        cell(hudTable, 0, 3, "Stop 2 (66%)", colorStop2Row, color_text, txtSize)
        cell(hudTable, 1, 3, formatPrice(stop2Price), colorStop2Row, color_text, txtSize)
        cell(hudTable, 2, 3, formatQty(q2), colorStop2Row, color_text, txtSize)
        cell(hudTable, 3, 3, "Scale out next 1/3 of position. Limits exposure on deeper pullback.", colorStop2Row, color_text, txtSize)
        
        // Row 4: Stop Level 3 (colored same as Stop 3 fill level)
        colorStop3Row = color_stop3_bg
        cell(hudTable, 0, 4, "Stop 3 (100%)", colorStop3Row, color_text, txtSize)
        cell(hudTable, 1, 4, formatPrice(stop3Price), colorStop3Row, color_text, txtSize)
        cell(hudTable, 2, 4, formatQty(q3), colorStop3Row, color_text, txtSize)
        cell(hudTable, 3, 4, "Hard Stop: Exit final 1/3 of position. Structural invalidation.", colorStop3Row, color_text, txtSize)
        
        // Row 5: Risk Summary
        float r = na(entryPriceVal) or na(finalStopPriceVal) ? 0.0 : math.abs(entryPriceVal - finalStopPriceVal)
        float initialRisk = positionSize * r
        float blendedRisk = (q1 * math.abs(entryPriceVal - stop1Price)) + (q2 * math.abs(entryPriceVal - stop2Price)) + (q3 * math.abs(entryPriceVal - stop3Price))
        float blendedPct  = initialRisk > 0.0 ? (blendedRisk / initialRisk) * 100.0 : 0.0
        float savedVal    = initialRisk - blendedRisk
        float savedPct    = initialRisk > 0.0 ? (savedVal / initialRisk) * 100.0 : 0.0
        
        cell(hudTable, 0, 5, "Initial Risk", color_title_bg, color_text, txtSize, text.format_bold)
        cell(hudTable, 1, 5, formatPrice(initialRisk), color_title_bg, color_text, txtSize, text.format_bold)
        cell(hudTable, 2, 5, "Blended Risk", color_title_bg, color_text, txtSize, text.format_bold)
        cell(hudTable, 3, 5, formatPrice(blendedRisk) + " (" + str.tostring(blendedPct, "#.#") + "%) | Saved: " + formatPrice(savedVal) + " (" + str.tostring(savedPct, "#.#") + "%)", color_title_bg, color_text, txtSize, text.format_bold)

